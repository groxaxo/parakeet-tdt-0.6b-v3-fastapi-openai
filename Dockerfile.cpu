# Parakeet TDT 0.6B ONNX - CPU Dockerfile
# High-performance speech transcription on CPU

FROM python:3.10-slim

LABEL maintainer="Parakeet TDT"
LABEL description="ONNX-optimized speech transcription service (CPU)"

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

RUN useradd --create-home --shell /bin/bash parakeet
WORKDIR /app

COPY requirements.txt .

# Keep the API/runtime dependency set identical to the GPU image, replacing
# only the execution-provider wheel with the Python-3.10-compatible CPU build.
RUN pip install --no-cache-dir --upgrade pip && \
    grep -v '^onnxruntime-gpu' requirements.txt > /tmp/requirements.cpu.txt && \
    pip install --no-cache-dir -r /tmp/requirements.cpu.txt && \
    pip install --no-cache-dir onnxruntime==1.23.2

COPY server.py .
COPY parakeet_service/ parakeet_service/
COPY app.py .
COPY templates/ templates/
COPY parakeet.png .

RUN mkdir -p temp_uploads models && \
    chown -R parakeet:parakeet /app

USER parakeet

ENV HF_HOME=/app/models
ENV HF_HUB_CACHE=/app/models
ENV HF_HUB_DISABLE_SYMLINKS_WARNING=true
ENV PYTHONUNBUFFERED=1
ENV PARAKEET_USE_GPU=false
ENV PARAKEET_DEFAULT_MODEL=parakeet-tdt-0.6b-v3
ENV PARAKEET_BATCHED=0

EXPOSE 5092

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:5092/healthz')" || exit 1

CMD ["python", "server.py"]
